<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product Id="*" 
           Name="Coruja Monitor Probe (Active Directory)" 
           Language="1046" 
           Version="1.0.2.0" 
           Manufacturer="Coruja Monitor" 
           UpgradeCode="22345678-2234-2234-2234-223456789012">
    
    <Package InstallerVersion="200" 
             Compressed="yes" 
             InstallScope="perMachine" 
             Description="Agente de monitoramento Coruja Monitor com Active Directory"
             Comments="Instalador com configuração de usuário do Active Directory" />

    <MajorUpgrade DowngradeErrorMessage="Uma versão mais recente já está instalada." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Propriedades para configuração -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="AD_DOMAIN" Value="" />
    <Property Id="AD_USERNAME" Value="coruja.monitor" />
    <Property Id="AD_PASSWORD" Value="" />
    <Property Id="API_URL" Value="http://192.168.31.161:8000" />
    <Property Id="PROBE_TOKEN" Value="" />

    <!-- Verificar privilégios de administrador -->
    <Condition Message="Este instalador requer privilégios de administrador.">
      Privileged
    </Condition>

    <!-- Estrutura de diretórios -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="CorujaMonitor">
          <Directory Id="ProbeFolder" Name="Probe" />
          <Directory Id="CollectorsFolder" Name="collectors" />
          <Directory Id="LogsFolder" Name="logs" />
        </Directory>
      </Directory>
      
      <!-- Menu Iniciar -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Coruja Monitor" />
      </Directory>
    </Directory>

    <!-- Componentes principais -->
    <DirectoryRef Id="ProbeFolder">
      <Component Id="ProbeCore" Guid="A1B2C3D4-E5F6-4A5B-8C9D-1E2F3A4B5C6D">
        <File Id="probe_core.py" Source="..\probe\probe_core.py" KeyPath="yes" />
      </Component>
      <Component Id="ProbeConfigPy" Guid="B2C3D4E5-F6A7-4B5C-9D1E-2F3A4B5C6D7E">
        <File Id="config.py" Source="..\probe\config.py" KeyPath="yes" />
      </Component>
      <Component Id="ProbeRequirements" Guid="C3D4E5F6-A7B8-4C5D-9E1F-3A4B5C6D7E8F">
        <File Id="requirements.txt" Source="..\probe\requirements.txt" KeyPath="yes" />
      </Component>
      
      <!-- Arquivo de configuração gerado -->
      <Component Id="ProbeConfigFile" Guid="E4F5A6B7-C8D9-4E5F-9A1B-6C7D8E9F0A1B">
        <File Id="probe_config.json" Name="probe_config.json" KeyPath="yes">
          <util:XmlFile Id="SetDomain" Action="setValue" ElementPath="/config/domain" Value="[AD_DOMAIN]" File="[ProbeFolder]probe_config.json" />
          <util:XmlFile Id="SetUsername" Action="setValue" ElementPath="/config/username" Value="[AD_USERNAME]" File="[ProbeFolder]probe_config.json" />
          <util:XmlFile Id="SetPassword" Action="setValue" ElementPath="/config/password" Value="[AD_PASSWORD]" File="[ProbeFolder]probe_config.json" />
          <util:XmlFile Id="SetApiUrl" Action="setValue" ElementPath="/config/api_url" Value="[API_URL]" File="[ProbeFolder]probe_config.json" />
          <util:XmlFile Id="SetToken" Action="setValue" ElementPath="/config/probe_token" Value="[PROBE_TOKEN]" File="[ProbeFolder]probe_config.json" />
        </File>
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="CollectorsFolder">
      <Component Id="SystemCollector" Guid="D4E5F6A7-B8C9-4D5E-9F1A-4B5C6D7E8F9A">
        <File Id="system_collector.py" Source="..\probe\collectors\system_collector.py" KeyPath="yes" />
      </Component>
      <Component Id="PingCollector" Guid="E5F6A7B8-C9D1-4E5F-9A1B-5C6D7E8F9A1B">
        <File Id="ping_collector.py" Source="..\probe\collectors\ping_collector.py" KeyPath="yes" />
      </Component>
      <Component Id="DockerCollector" Guid="F6A7B8C9-D1E2-4F5A-9B1C-6D7E8F9A1B2C">
        <File Id="docker_collector.py" Source="..\probe\collectors\docker_collector.py" KeyPath="yes" />
      </Component>
      <Component Id="SnmpCollector" Guid="A7B8C9D1-E2F3-4A5B-9C1D-7E8F9A1B2C3D">
        <File Id="snmp_collector.py" Source="..\probe\collectors\snmp_collector.py" KeyPath="yes" />
      </Component>
      <Component Id="KubernetesCollector" Guid="B8C9D1E2-F3A4-4B5C-9D1E-8F9A1B2C3D4E">
        <File Id="kubernetes_collector.py" Source="..\probe\collectors\kubernetes_collector.py" KeyPath="yes" />
      </Component>
      <Component Id="WmiCollector" Guid="C9D1E2F3-A4B5-4C5D-9E1F-9A1B2C3D4E5F">
        <File Id="wmi_remote_collector.py" Source="..\probe\collectors\wmi_remote_collector.py" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Atalhos -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcuts" Guid="D1E2F3A4-B5C6-4D5E-9F1A-2B3C4D5E6F7A">
        <Shortcut Id="StartProbeShortcut"
                  Name="Iniciar Coruja Probe"
                  Description="Inicia o agente de monitoramento"
                  Target="[System64Folder]cmd.exe"
                  Arguments='/k cd /d "[ProbeFolder]" &amp;&amp; python probe_core.py'
                  WorkingDirectory="ProbeFolder" />
        
        <Shortcut Id="ConfigProbeShortcut"
                  Name="Configurar Probe"
                  Description="Abre o arquivo de configuração"
                  Target="[System64Folder]notepad.exe"
                  Arguments='"[ProbeFolder]probe_config.json"'
                  WorkingDirectory="ProbeFolder" />
        
        <Shortcut Id="UninstallShortcut"
                  Name="Desinstalar Coruja Probe"
                  Description="Remove o Coruja Monitor Probe"
                  Target="[System64Folder]msiexec.exe"
                  Arguments="/x [ProductCode]" />
        
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" 
                       Key="Software\CorujaMonitor\Probe" 
                       Name="installed" 
                       Type="integer" 
                       Value="1" 
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Custom Actions -->
    <CustomAction Id="InstallPythonDeps" 
                  Directory="ProbeFolder"
                  ExeCommand='cmd.exe /c "pip install -r requirements.txt"'
                  Execute="deferred" 
                  Return="ignore" 
                  Impersonate="no" />
    
    <CustomAction Id="CreateTaskScheduler" 
                  Directory="ProbeFolder"
                  ExeCommand='cmd.exe /c "schtasks /create /tn CorujaMonitorProbe /tr \"cmd /c cd /d [ProbeFolder] &amp;&amp; python probe_core.py\" /sc onstart /delay 0000:30 /rl highest /ru [AD_DOMAIN]\[AD_USERNAME] /rp [AD_PASSWORD] /f"'
                  Execute="deferred" 
                  Return="ignore" 
                  Impersonate="no" />
    
    <CustomAction Id="StartProbe" 
                  Directory="ProbeFolder"
                  ExeCommand='cmd.exe /c "schtasks /run /tn CorujaMonitorProbe"'
                  Execute="deferred" 
                  Return="ignore" 
                  Impersonate="no" />
    
    <CustomAction Id="StopProbe" 
                  Directory="ProbeFolder"
                  ExeCommand='cmd.exe /c "taskkill /f /im python.exe"'
                  Execute="deferred" 
                  Return="ignore" 
                  Impersonate="no" />
    
    <CustomAction Id="DeleteTask" 
                  Directory="ProbeFolder"
                  ExeCommand='cmd.exe /c "schtasks /delete /tn CorujaMonitorProbe /f"'
                  Execute="deferred" 
                  Return="ignore" 
                  Impersonate="no" />

    <!-- Sequência de instalação -->
    <InstallExecuteSequence>
      <Custom Action="InstallPythonDeps" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="CreateTaskScheduler" After="InstallPythonDeps">NOT Installed</Custom>
      <Custom Action="StartProbe" After="CreateTaskScheduler">NOT Installed</Custom>
      
      <!-- Desinstalação -->
      <Custom Action="StopProbe" Before="RemoveFiles">Installed AND NOT REINSTALL</Custom>
      <Custom Action="DeleteTask" After="StopProbe">Installed AND NOT REINSTALL</Custom>
    </InstallExecuteSequence>

    <!-- Features -->
    <Feature Id="ProductFeature" Title="Coruja Monitor Probe" Level="1">
      <ComponentRef Id="ProbeCore" />
      <ComponentRef Id="ProbeConfigPy" />
      <ComponentRef Id="ProbeRequirements" />
      <ComponentRef Id="ProbeConfigFile" />
      <ComponentRef Id="SystemCollector" />
      <ComponentRef Id="PingCollector" />
      <ComponentRef Id="DockerCollector" />
      <ComponentRef Id="SnmpCollector" />
      <ComponentRef Id="KubernetesCollector" />
      <ComponentRef Id="WmiCollector" />
      <ComponentRef Id="ApplicationShortcuts" />
    </Feature>

    <!-- Interface do instalador com diálogos customizados -->
    <UI>
      <UIRef Id="WixUI_InstallDir" />
      <UIRef Id="WixUI_ErrorProgressText" />
      
      <!-- Diálogo de configuração AD -->
      <Dialog Id="ADConfigDlg" Width="370" Height="270" Title="Configuração Active Directory">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Configuração do Active Directory" />
        
        <Control Id="DomainLabel" Type="Text" X="20" Y="60" Width="290" Height="15" NoPrefix="yes" Text="Domínio:" />
        <Control Id="DomainEdit" Type="Edit" X="20" Y="75" Width="290" Height="18" Property="AD_DOMAIN" />
        
        <Control Id="UsernameLabel" Type="Text" X="20" Y="100" Width="290" Height="15" NoPrefix="yes" Text="Usuário:" />
        <Control Id="UsernameEdit" Type="Edit" X="20" Y="115" Width="290" Height="18" Property="AD_USERNAME" />
        
        <Control Id="PasswordLabel" Type="Text" X="20" Y="140" Width="290" Height="15" NoPrefix="yes" Text="Senha:" />
        <Control Id="PasswordEdit" Type="Edit" X="20" Y="155" Width="290" Height="18" Property="AD_PASSWORD" Password="yes" />
        
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Voltar">
          <Publish Event="NewDialog" Value="LicenseAgreementDlg">1</Publish>
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Avançar">
          <Publish Event="NewDialog" Value="APIConfigDlg">1</Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancelar">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>
      
      <!-- Diálogo de configuração API -->
      <Dialog Id="APIConfigDlg" Width="370" Height="270" Title="Configuração da API">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Configuração da API" />
        
        <Control Id="ApiUrlLabel" Type="Text" X="20" Y="60" Width="290" Height="15" NoPrefix="yes" Text="URL da API:" />
        <Control Id="ApiUrlEdit" Type="Edit" X="20" Y="75" Width="290" Height="18" Property="API_URL" />
        
        <Control Id="TokenLabel" Type="Text" X="20" Y="100" Width="290" Height="30" NoPrefix="yes" Text="Token da Probe (obter no dashboard em Gerenciamento → Empresas):" />
        <Control Id="TokenEdit" Type="Edit" X="20" Y="135" Width="290" Height="18" Property="PROBE_TOKEN" />
        
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Voltar">
          <Publish Event="NewDialog" Value="ADConfigDlg">1</Publish>
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Avançar">
          <Publish Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancelar">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>
      
      <!-- Adicionar diálogos à sequência -->
      <Publish Dialog="LicenseAgreementDlg" Control="Next" Event="NewDialog" Value="ADConfigDlg" Order="2">LicenseAccepted = "1"</Publish>
      <Publish Dialog="ADConfigDlg" Control="Back" Event="NewDialog" Value="LicenseAgreementDlg">1</Publish>
      <Publish Dialog="APIConfigDlg" Control="Back" Event="NewDialog" Value="ADConfigDlg">1</Publish>
    </UI>
  </Product>
</Wix>
