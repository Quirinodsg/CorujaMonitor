# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=coruja_monitor
POSTGRES_USER=coruja
POSTGRES_PASSWORD=coruja_secure_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# API Service
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-this-to-a-secure-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# AI Agent
AI_PROVIDER=ollama
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
AI_MODEL=gpt-4

# Worker
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Probe
PROBE_TOKEN_EXPIRATION_DAYS=365
PROBE_HEARTBEAT_INTERVAL_SECONDS=60

# Monitoring
METRICS_RETENTION_DAYS=90
INCIDENT_RETENTION_DAYS=365

# Localization
DEFAULT_LANGUAGE=pt-BR
SUPPORTED_LANGUAGES=en,pt-BR

# Streaming Architecture (Fase 12)
REDIS_URL=redis://redis:6379/0
METRICS_STREAM_KEY=metrics_stream
EVENTS_STREAM_KEY=events_stream
STREAM_CONSUMER_GROUP=coruja-consumers
STREAM_BATCH_SIZE=500
