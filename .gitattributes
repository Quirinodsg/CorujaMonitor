# Auto detect text files and perform LF normalization
* text=auto

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix scripts
*.sh text eol=lf

# Python
*.py text eol=lf

# JavaScript
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Documentation
*.md text eol=lf
